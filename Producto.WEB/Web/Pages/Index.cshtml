@page
@model Web.Pages.IndexModel
@{
    ViewData["Title"] = "Productos";
}

<section class="page-card">
    <div class="blank-card text-center">
        <div class="placeholder-avatar mx-auto mb-3">
            <i class="bi bi-box-seam-fill"></i>
        </div>
        <h4>Redireccionando al módulo de productos...</h4>
        <p>Si la redirección no ocurre automáticamente, usa el acceso directo de abajo.</p>
        <a class="btn-shell" asp-page="/Productos/Index">
            <i class="bi bi-box-seam-fill"></i>
            Ir a productos
        </a>
    </div>
</section>
